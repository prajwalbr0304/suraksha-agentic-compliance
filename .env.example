# Copy to .env.local — do not commit .env.local

# Supabase (browser-safe)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_DOCUMENTS_BUCKET=

# Supabase server-only (never expose to client)
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_PROJECT_ID=

# Postgres (Dashboard → Settings → Database → Database password). Required for:
#   node scripts/apply-db-migration.cjs …
#   node scripts/apply-enterprise-migrations.cjs
#   npm run db:apply-audit-enums
# SUPABASE_DB_PASSWORD=
# Optional pooler host (default: aws-1-ap-southeast-2.pooler.supabase.com)
# SUPABASE_POOLER_HOST=

# Authorization is always enforced by the application. Keep this explicit for
# deployment documentation and older environments.
SURAKSHA_AUTH_REQUIRED=true

# Canonical obligation extraction runs through the Google ADK agent pipeline
# (Gemini) via the agent-service. The legacy local Ollama route at
# /api/extract-obligations is disabled unless this flag is set to 1.
ENABLE_LOCAL_EXTRACTION=0

# Optional: local LLM (only used when ENABLE_LOCAL_EXTRACTION=1)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:1.5b
OLLAMA_MAX_CHUNKS=2

# Optional: Playwright UI capture (dev only)
# CAPTURE_BASE_URL=http://localhost:3000

# Playwright E2E (`npm run test:playwright`) — defaults match scripts/seed-enterprise.cjs
# E2E_BASE_URL=http://localhost:3000
# E2E_FOUNDER_EMAIL=founder@suraksha.local
# E2E_FOUNDER_PASSWORD=SurakshaFounder@2026
# E2E_MANAGER_EMAIL=manager@hdfc-bank.suraksha.local
# E2E_MANAGER_PASSWORD=SurakshaManager@2026
# E2E_COMPLIANCE_EMAIL=compliance@suraksha.local
# E2E_COMPLIANCE_PASSWORD=SurakshaCompliance@2026

# Upload pipeline script: npm run test:upload-pipeline -- "C:\path\to\file.pdf"
# (defaults below match a local Test Bank manager — override for your tenant)
# SURAKSHA_UPLOAD_TEST_EMAIL=manager@testbank.com
# SURAKSHA_UPLOAD_TEST_PASSWORD=
# SURAKSHA_TEST_ORG_SLUG=test-cooperative-bank
# SURAKSHA_TEST_BASE_URL=http://localhost:3000
# SURAKSHA_TEST_PDF_PATH=C:\path\to\circular.pdf
