# --- Suraksha ADK Agent Service ---

# Google Gemini (AI Studio free tier): https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_from_ai_studio
GEMINI_MODEL=gemini-2.5-flash

# --- Local LLM (Ollama) — avoids Gemini free-tier quotas; requires `pip install litellm` + Ollama running ---
# SURAKSHA_USE_LOCAL_LLM=true
# LOCAL_LLM_API_BASE=http://127.0.0.1:11434
# LOCAL_LLM_MODEL=ollama_chat/llama3.2

# Supabase (same project as the Next.js app) — service role bypasses RLS
SUPABASE_URL=https://stggdwlxsldonuhrxbhx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InN0Z2dkd2x4c2xkb251aHJ4Ymh4Iiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTc3ODA0NTg4MiwiZXhwIjoyMDkzNjIxODgyfQ.641AiX7-TR4S41CJ0AQLxZaj7LC-7aS1gWPeHCXCINc

# Shared secret the Next.js app sends in X-Agent-Secret to call this service
AGENT_SHARED_SECRET=change-me-to-a-long-random-string

# Service host/port
AGENT_HOST=0.0.0.0
AGENT_PORT=8088

# Autonomous scheduler (set to 0 to disable background loops)
ENABLE_SCHEDULER=1
WATCH_INTERVAL_MINUTES=60
VALIDATE_INTERVAL_HOURS=24

# Optional — same bucket as Next.js (default: compliance-documents)
# NEXT_PUBLIC_SUPABASE_DOCUMENTS_BUCKET=compliance-documents

# Optional — inject sample RSS rows when a feed fails (default: off; demos only)
# SURAKSHA_REGULATORY_FEED_SAMPLES=false

# Optional — require a stored PDF before creating obligations (default: off)
# AUTOMATIC_PDF_STRICT=false

# Optional — PDF download cap in bytes (default ~35 MB)
# SURAKSHA_PDF_MAX_BYTES=36700160

# Optional — if extracted PDF text is shorter than this, merge RSS summary (default 200)
# SURAKSHA_PDF_MIN_TEXT_CHARS=200

# Optional — per ADK agent asyncio timeout in seconds (default: 180 Gemini, 900 when SURAKSHA_USE_LOCAL_LLM=true). Increase if you see "Root node … was cancelled" in logs on Ollama.
# SURAKSHA_AGENT_LLM_TIMEOUT_SEC=1200

# Optional — LiteLLM HTTP read timeout to Ollama in seconds (default: max(1800, 2×agent timeout+300) when local). Litellm's own default (~600) caused httpx.ReadTimeout on long drift/audit calls.
# SURAKSHA_LITELLM_HTTP_TIMEOUT_SEC=2400

# Optional — when org has no custom regulatory_sources, only scan RBI from DEFAULT_FEEDS (debug / India-only runs).
# SURAKSHA_REGULATORY_FEEDS_RBI_ONLY=false

# Dev only — disable TLS verify for Gemini HTTP (INSECURE; never production)
# SURAKSHA_INSECURE_LLM_SSL=false
